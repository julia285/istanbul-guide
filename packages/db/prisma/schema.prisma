// Istanbul Guide — core database schema
// See /Users/larisapogorelova/.claude/plans/wild-hopping-pearl.md section 3 for the design rationale.
//
// Notes:
// - `coordinates` / `boundary` use PostGIS geography types via `Unsupported(...)`.
//   Prisma Client can't query these directly — use $queryRaw with parameterized
//   ST_* functions for anything geo (nearby search, district containment, etc).
// - `embedding` uses pgvector via `Unsupported(...)` for the same reason — raw
//   SQL with the `<=>` cosine-distance operator for similarity search.
// - `locale` is a plain string ("en" | "tr" today), not an enum, so adding a
//   language later is a data change, not a schema migration.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // "native" covers local dev (darwin-arm64 on this machine); Vercel's
  // serverless functions run on Amazon Linux 2023, which needs its own
  // engine binary bundled alongside — without this, a deploy built with
  // only the local platform's engine fails at runtime with
  // "could not locate the Query Engine for runtime ...".
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  // Fixed, non-pnpm-hashed output path — Next.js's webpack bundling mangles
  // the query engine's runtime __dirname-relative lookup when the client
  // lives deep inside a pnpm content-addressed store path. See
  // https://pris.ly/d/nextjs-prisma-vercel and github.com/prisma/prisma/issues/17064
  //
  // Lives as a sibling of src/ and dist/ (not inside src/) so the same
  // relative import ("../generated/client") resolves correctly from both
  // src/index.ts (dev/typecheck) and the compiled dist/index.js (prod) —
  // src/ and dist/ are both one level below this package root.
  output          = "../generated/client"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // Supabase's PgBouncer (transaction mode, used by DATABASE_URL) doesn't
  // support the prepared statements `prisma migrate` needs — migrations run
  // through the unpooled connection instead.
  directUrl  = env("DIRECT_URL")
  extensions = [postgis, pgvector(map: "vector")]
}

// ---------------------------------------------------------------------------
// Sources & raw ingestion
// ---------------------------------------------------------------------------

enum SourceType {
  API
  RSS
  SCRAPE
}

// HEALTHY: recent runs succeeding. DEGRADED: at least one recent failure but
// not yet at the disable threshold. FAILED: consecutiveFailures has crossed
// the threshold — autoPublishEnabled gets flipped off automatically so a
// broken selector/schema change can't silently publish garbage.
enum SourceHealthStatus {
  HEALTHY
  DEGRADED
  FAILED
}

model Source {
  id                  String              @id @default(cuid())
  name                String
  slug                String              @unique
  baseUrl             String
  type                SourceType
  scrapeConfig        Json?
  legalNotes          String?
  active              Boolean             @default(true)
  // Default priority tier for EventSource rows created from this source —
  // 0 = official organizer/venue, 1 = official ticket seller, 2 = aggregator,
  // 3 = editorial/community. Lower wins when the same event is reported by
  // multiple sources. Per-EventSource priority can still be overridden.
  priority            Int                 @default(2)
  // How often the scheduler should consider this source due, per-source
  // (major ticket platforms 120-240, official venues 240-360, museums 720,
  // community sources 360-720) — see architecture doc scheduling section.
  intervalMinutes     Int                 @default(60)
  lastRunAt           DateTime?
  lastSuccessAt       DateTime?
  lastFailureAt       DateTime?
  consecutiveFailures Int                 @default(0)
  // Auto-disabled (not `active`) when consecutiveFailures crosses the
  // threshold in the scheduler — keeps raw_listings flowing to REVIEW
  // manually rather than trusting a possibly-broken parser to auto-publish.
  autoPublishEnabled  Boolean             @default(true)
  healthStatus        SourceHealthStatus?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  rawListings  RawListing[]
  places       Place[]
  events       Event[]
  eventSources EventSource[]
  parserRuns   ParserRun[]

  @@map("sources")
}

enum ParserRunStatus {
  RUNNING
  SUCCESS
  FAILED
}

// One row per scheduler tick per source — the run-history the single mutable
// Source.healthStatus/lastRunAt couldn't provide (no way to see "last 10
// runs" or compute consecutive failures from those alone).
model ParserRun {
  id              String          @id @default(cuid())
  sourceId        String
  startedAt       DateTime        @default(now())
  finishedAt      DateTime?
  durationMs      Int?
  status          ParserRunStatus @default(RUNNING)
  discoveredCount Int             @default(0)
  newCount        Int             @default(0)
  updatedCount    Int             @default(0)
  rejectedCount   Int             @default(0)
  errorCount      Int             @default(0)
  errorSummary    Json?

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, startedAt])
  @@map("parser_runs")
}

enum RawListingStatus {
  PENDING
  PROCESSED
  ERROR
}

model RawListing {
  id               String           @id @default(cuid())
  sourceId         String
  sourceExternalId String
  rawPayload       Json
  contentHash      String
  fetchedAt        DateTime         @default(now())
  status           RawListingStatus @default(PENDING)
  errorMessage     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  source      Source       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  eventSource EventSource?

  @@unique([sourceId, sourceExternalId])
  @@index([status])
  @@index([contentHash])
  @@map("raw_listings")
}

// ---------------------------------------------------------------------------
// Shared enums
// ---------------------------------------------------------------------------

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  REJECTED
  EXPIRED
}

enum PriceTier {
  FREE
  BUDGET
  MODERATE
  EXPENSIVE
}

// ---------------------------------------------------------------------------
// Taxonomy: District / Category / Tag
// ---------------------------------------------------------------------------

model District {
  id        String                                  @id @default(cuid())
  slug      String                                  @unique
  boundary  Unsupported("geography(Polygon,4326)")?
  centerLat Float?
  centerLng Float?
  createdAt DateTime                                @default(now())
  updatedAt DateTime                                @updatedAt

  translations DistrictTranslation[]
  places       Place[]
  events       Event[]

  @@map("districts")
}

model DistrictTranslation {
  id          String  @id @default(cuid())
  districtId  String
  locale      String
  name        String
  description String?

  district District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@unique([districtId, locale])
  @@map("district_translations")
}

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  parentId  String?
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  translations CategoryTranslation[]
  places       Place[]
  events       Event[]

  @@map("categories")
}

model CategoryTranslation {
  id          String  @id @default(cuid())
  categoryId  String
  locale      String
  name        String
  description String?

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@map("category_translations")
}

model Tag {
  id        String   @id @default(cuid())
  slug      String   @unique
  createdAt DateTime @default(now())

  translations TagTranslation[]
  placeTags    PlaceTag[]
  eventTags    EventTag[]

  @@map("tags")
}

model TagTranslation {
  id     String @id @default(cuid())
  tagId  String
  locale String
  name   String

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, locale])
  @@map("tag_translations")
}

// ---------------------------------------------------------------------------
// Place (evergreen venues: restaurants, cafes, bars, museums, shops, ...)
// ---------------------------------------------------------------------------

model Place {
  id                String                                @id @default(cuid())
  sourceId          String?
  // Reference/attribution link (e.g. the Michelin Guide page or an
  // official history writeup) — mirrors Event.sourceUrl. Not necessarily
  // the venue's own site; that goes in `contact.website` when known.
  sourceUrl         String?
  // Free-text street address — unlike events (which only need a district
  // for filtering), a restaurant is useless to a visitor without one.
  addressText       String?
  categoryId        String
  districtId        String?
  coordinates       Unsupported("geography(Point,4326)")?
  priceTier         PriceTier?
  hours             Json?
  contact           Json?
  status            ContentStatus                         @default(DRAFT)
  confidenceScore   Float?
  canonicalDedupeId String?
  createdAt         DateTime                              @default(now())
  updatedAt         DateTime                              @updatedAt
  publishedAt       DateTime?

  source          Source?   @relation(fields: [sourceId], references: [id])
  category        Category  @relation(fields: [categoryId], references: [id])
  district        District? @relation(fields: [districtId], references: [id])
  canonicalDedupe Place?    @relation("PlaceDedupe", fields: [canonicalDedupeId], references: [id])
  duplicates      Place[]   @relation("PlaceDedupe")

  translations PlaceTranslation[]
  tags         PlaceTag[]
  media        Media[]
  events       Event[]
  articleItems ArticleItem[]

  @@index([status])
  @@index([categoryId])
  @@index([districtId])
  @@map("places")
}

model PlaceTranslation {
  id              String   @id @default(cuid())
  placeId         String
  locale          String
  name            String
  description     String
  slug            String
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  keywords        String[]
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  schemaJsonLd    Json?

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, locale])
  @@unique([locale, slug])
  @@map("place_translations")
}

model PlaceTag {
  placeId String
  tagId   String

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([placeId, tagId])
  @@map("place_tags")
}

// ---------------------------------------------------------------------------
// Event (time-bound: concerts, festivals, exhibitions, weekend happenings)
// ---------------------------------------------------------------------------

// Factual state of the event itself, independent of moderation (`status`).
// An event can be PUBLISHED and SOLD_OUT at the same time, for example.
enum EventState {
  SCHEDULED
  POSTPONED
  CANCELLED
  SOLD_OUT
}

model Event {
  id                     String                                @id @default(cuid())
  // "Primary" source — the highest-priority EventSource row for this event,
  // kept in sync with the eventSources relation below. Multiple sources can
  // report the same event; this pair is what public pages render/link to.
  sourceId               String?
  // The specific source article/listing URL this event was collected from
  // (distinct from `source`, which is the site as a whole) — shown as an
  // outbound "more info / tickets" link, and doubles as attribution back
  // to the source per the sourcing strategy in the architecture doc.
  sourceUrl              String?
  // The actual ticket-seller URL (Passo, Biletinial, Bugece, etc.), found
  // within the source article rather than in the RSS excerpt itself —
  // distinct from sourceUrl (the article) since they're often different
  // sites. Preferred over sourceUrl for the "Get Tickets" link when set.
  ticketUrl              String?
  organizerName          String?
  placeId                String?
  standaloneLocation     Json?
  coordinates            Unsupported("geography(Point,4326)")?
  categoryId             String
  districtId             String?
  startAt                DateTime
  endAt                  DateTime?
  recurrence             Json?
  price                  Json?
  eventState             EventState                            @default(SCHEDULED)
  // Set when a previously-seen event disappears from a source's listing.
  // The event is NOT deleted or immediately unpublished — it's flagged so
  // the next run(s) can try to reconfirm it against other sources before
  // any status change.
  missingFromSourceSince DateTime?
  status                 ContentStatus                         @default(DRAFT)
  confidenceScore        Float?
  createdAt              DateTime                              @default(now())
  updatedAt              DateTime                              @updatedAt
  publishedAt            DateTime?

  source   Source?   @relation(fields: [sourceId], references: [id])
  place    Place?    @relation(fields: [placeId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])
  district District? @relation(fields: [districtId], references: [id])

  translations EventTranslation[]
  tags         EventTag[]
  media        Media[]
  articleItems ArticleItem[]
  eventSources EventSource[]

  @@index([status])
  @@index([startAt])
  @@index([categoryId])
  @@index([districtId])
  @@map("events")
}

// Ledger of every source that has reported a given canonical Event —
// "create one canonical event and preserve all source references" rather
// than deleting duplicates. `priority` follows the source-conflict order
// from the architecture doc: 0 = official organizer/venue, 1 = official
// ticket seller, 2 = aggregator, 3 = editorial/community. The lowest-
// priority-number row is mirrored onto Event.sourceId/sourceUrl.
model EventSource {
  id                String   @id @default(cuid())
  eventId           String
  sourceId          String
  rawListingId      String?  @unique
  sourceExternalId  String
  sourceUrl         String
  priority          Int      @default(2)
  isPrimary         Boolean  @default(false)
  // Fields where this source's value disagreed with the canonical event at
  // merge time (e.g. { "startAt": "2026-08-01T19:00:00Z" }) — surfaced in
  // the admin review/conflicts screen rather than silently overwritten.
  conflictingFields Json?
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime @default(now())

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  source     Source      @relation(fields: [sourceId], references: [id])
  rawListing RawListing? @relation(fields: [rawListingId], references: [id])

  @@unique([sourceId, sourceExternalId])
  @@index([eventId])
  @@map("event_sources")
}

model EventTranslation {
  id              String   @id @default(cuid())
  eventId         String
  locale          String
  name            String
  description     String
  slug            String
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  keywords        String[]
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  schemaJsonLd    Json?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, locale])
  @@unique([locale, slug])
  @@map("event_translations")
}

model EventTag {
  eventId String
  tagId   String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([eventId, tagId])
  @@map("event_tags")
}

// ---------------------------------------------------------------------------
// Article (Content Agent output: listicles, guides, news) + Guide items
// ---------------------------------------------------------------------------

enum ArticleType {
  LISTICLE
  GUIDE
  NEWS
}

model Article {
  id              String        @id @default(cuid())
  type            ArticleType
  status          ContentStatus @default(DRAFT)
  confidenceScore Float?
  generatedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishedAt     DateTime?

  translations ArticleTranslation[]
  items        ArticleItem[]

  @@index([status])
  @@map("articles")
}

model ArticleTranslation {
  id              String  @id @default(cuid())
  articleId       String
  locale          String
  title           String
  body            String
  metaTitle       String?
  metaDescription String?
  slug            String
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  schemaJsonLd    Json?

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@unique([locale, slug])
  @@map("article_translations")
}

model ArticleItem {
  id        String  @id @default(cuid())
  articleId String
  placeId   String?
  eventId   String?
  position  Int

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  place   Place?  @relation(fields: [placeId], references: [id])
  event   Event?  @relation(fields: [eventId], references: [id])

  @@index([articleId])
  @@map("article_items")
}

// ---------------------------------------------------------------------------
// Media
// ---------------------------------------------------------------------------

enum MediaOwnerType {
  PLACE
  EVENT
  ARTICLE
}

model Media {
  id                String         @id @default(cuid())
  ownerType         MediaOwnerType
  placeId           String?
  eventId           String?
  url               String
  altText           Json?
  sourceAttribution String?
  licenseStatus     String?
  // Set true when a scraped image's usage rights aren't confirmed (the
  // default for anything pulled from a new source) — surfaced as an admin
  // flag rather than blocking publish outright, per the images policy.
  rightsUncertain   Boolean        @default(false)
  createdAt         DateTime       @default(now())

  place Place? @relation(fields: [placeId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([ownerType, placeId])
  @@index([ownerType, eventId])
  @@map("media")
}

// ---------------------------------------------------------------------------
// AI pipeline observability
// ---------------------------------------------------------------------------

model AiLog {
  id              String   @id @default(cuid())
  entityType      String
  entityId        String
  agentName       String
  inputSnapshot   Json?
  outputSnapshot  Json?
  modelUsed       String?
  tokensUsed      Int?
  costUsd         Decimal? @db.Decimal(10, 6)
  confidenceScore Float?
  status          String
  createdAt       DateTime @default(now())

  @@index([entityType, entityId])
  @@index([agentName])
  @@index([createdAt])
  @@map("ai_logs")
}

enum ReviewStatus {
  PENDING
  IN_REVIEW
  RESOLVED
}

model ReviewQueueItem {
  id              String       @id @default(cuid())
  entityType      String
  entityId        String
  reason          String
  confidenceScore Float?
  assignedTo      String?
  status          ReviewStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  resolvedAt      DateTime?

  @@index([status])
  @@index([entityType, entityId])
  @@map("review_queue")
}

model Embedding {
  id         String                      @id @default(cuid())
  entityType String
  entityId   String
  embedding  Unsupported("vector(1536)")
  model      String
  createdAt  DateTime                    @default(now())

  @@unique([entityType, entityId, model])
  @@map("embeddings")
}

// ---------------------------------------------------------------------------
// SEO / redirects
// ---------------------------------------------------------------------------

enum RedirectType {
  PERMANENT
  TEMPORARY
}

model Redirect {
  id        String       @id @default(cuid())
  fromPath  String       @unique
  toPath    String
  type      RedirectType @default(PERMANENT)
  createdAt DateTime     @default(now())

  @@map("redirects")
}

// ---------------------------------------------------------------------------
// Users (admin staff now, public accounts later)
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
  USER
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  role       UserRole @default(USER)
  localePref String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("users")
}
